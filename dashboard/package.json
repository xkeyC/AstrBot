    "@tiptap/vue-3": "2.1.7",
    "apexcharts": "3.42.0",
    "axios": "1.13.5",
    "axios-mock-adapter": "^1.22.0",
    "chance": "1.1.11",
    "date-fns": "2.30.0",
    "dompurify": "^3.3.2",
    "event-source-polyfill": "^1.0.31",
    "js-md5": "^0.8.3",
    "katex": "^0.16.27",
    "lodash": "4.17.23",
    "markdown-it": "^14.1.1",
    "markstream-vue": "^0.0.6",
    "mermaid": "^11.12.2",
    "monaco-editor": "^0.52.2",
    "pinia": "2.1.6",
    "pinyin-pro": "^3.26.0",
    "qrcode": "^1.5.4",
    "shiki": "^3.20.0",
    "stream-markdown": "^0.0.13",
    "vee-validate": "4.11.3",
    "vite-plugin-vuetify": "2.1.3",
    "vue": "3.3.4",
    "vue-i18n": "^11.1.5",
    "vue-router": "4.2.4",
    "vue3-apexcharts": "1.4.4",
    "vue3-print-nb": "0.1.4",
    "vuetify": "3.7.11",
    "yup": "1.2.0"
