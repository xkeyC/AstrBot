    "eslint": "8.48.0",
    "eslint-plugin-vue": "9.17.0",
    "prettier": "3.0.2",
    "sass": "1.66.1",
    "sass-loader": "13.3.2",
    "subset-font": "^2.4.0",
    "typescript": "5.1.6",
    "vite": "6.4.1",
    "vite-plugin-webfont-dl": "^3.12.0",
    "vue-cli-plugin-vuetify": "2.5.8",
    "vue-tsc": "1.8.8",
    "vuetify-loader": "^2.0.0-alpha.9"
  },
  "pnpm": {
    "overrides": {
      "immutable": "4.3.8",
      "lodash-es": "4.17.23"
