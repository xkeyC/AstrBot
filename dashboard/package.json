  "devDependencies": {
    "@mdi/font": "7.2.96",
    "@rushstack/eslint-patch": "1.3.3",
    "@types/chance": "1.1.3",
    "@types/dompurify": "^3.0.5",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.5.7",
    "@vitejs/plugin-vue": "5.2.4",
    "@vue/eslint-config-prettier": "8.0.0",
    "@vue/eslint-config-typescript": "11.0.3",
